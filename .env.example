# Environment Variables — Customer Intelligence System v2.0
# Copy file ini menjadi .env dan isi nilainya
# JANGAN commit file .env ke Git

# =====================================================
# GOOGLE BIGQUERY
# =====================================================
GOOGLE_APPLICATION_CREDENTIALS=key.json

# =====================================================
# API SECURITY (FastAPI)
# =====================================================
# API_KEY=your-secure-api-key-here

# =====================================================
# DATABASE CONFIGURATION
# (Pilih salah satu: Supabase atau Local PostgreSQL)
# =====================================================

# ---> OPSI 1: SUPABASE CLOUD (Disarankan untuk Deployment)
DB_USER=postgres.[GANTI_DENGAN_ID_POOLER]
DB_PASSWORD=[GANTI_DENGAN_PASS_ANDA]
DB_HOST=aws-1-ap-southeast-1.pooler.supabase.com
DB_PORT=5432
DB_NAME=postgres

# # ---> OPSI 2: LOCAL POSTGRESQL (Untuk pengembangan lokal)
# DB_USER=postgres
# DB_PASSWORD=admin
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=thelook_ecommerce

# =====================================================
# DATABASE URL (format lengkap untuk SQLAlchemy)
# =====================================================
# DATABASE_URL=postgresql://postgres:admin@localhost:5432/thelook_ecommerce

# ---> Read-Only URL (untuk RAG AI Assistant — keamanan query)
# Buat user PostgreSQL dengan akses SELECT only, lalu isi di sini.
# DATABASE_URL_READONLY=postgresql://readonly_user:pass@localhost:5432/thelook_ecommerce

# =====================================================
# RAG AI ASSISTANT (Groq / LangChain)
# =====================================================
# Diperlukan hanya jika menggunakan endpoint /insights/ask
# Dapatkan key dari: https://console.groq.com/keys
# GROQ_API_KEY=your-groq-api-key-here

# =====================================================
# MLFLOW EXPERIMENT TRACKING
# =====================================================
# Default: http://localhost:5000 (via docker-compose mlflow service)
# Untuk remote tracking (misal DagsHub):
# MLFLOW_TRACKING_URI=https://dagshub.com/Rxseboy/E-Commerce-Customer-Intelligence-System.mlflow
MLFLOW_TRACKING_URI=http://localhost:5000

# =====================================================
# AIRFLOW CONFIGURATION
# =====================================================
AIRFLOW_SECRET_KEY=ecommerce-portfolio-secret-key-2024
AIRFLOW_ADMIN_PASSWORD=admin
